// ContainPoint - SPCC Compliance SaaS
// Phase 1 Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum UserRole {
  ORG_ADMIN
  FACILITY_MANAGER
  INSPECTOR
  REVIEWER
  READ_ONLY_AUDITOR
}

enum FacilityStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ApplicabilityStatus {
  NOT_ASSESSED
  APPLICABLE
  NOT_APPLICABLE
}

enum QualificationTier {
  NOT_QUALIFIED
  TIER_I
  TIER_II
  PE_CERTIFIED_ONLY
}

enum AssetType {
  BULK_STORAGE_CONTAINER
  DRUM_TOTE
  TRANSFORMER
  MOBILE_CONTAINER
  LOADING_UNLOADING_AREA
  TRANSFER_AREA
  OTHER
}

enum OilTypeCategory {
  DIESEL
  GASOLINE
  HYDRAULIC
  LUBE
  USED_OIL
  TRANSFORMER
  CRUDE
  OTHER
}

enum ContainmentType {
  DIKE_BERM
  PALLET
  BUILDING_FLOOR
  SUMP
  DOUBLE_WALL
  OTHER
}

enum FileObjectType {
  FACILITY
  ASSET
  CONTAINMENT_UNIT
  INSPECTION_RUN
  CORRECTIVE_ACTION
  TRAINING_EVENT
  INCIDENT
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  RETIRED
}

enum ConditionStatus {
  GOOD
  FAIR
  POOR
  REQUIRES_ATTENTION
}

// Phase 2 enums
enum RequirementSourceType {
  REGULATION
  GUIDANCE
  INTERPRETATION
  ENFORCEMENT_EXAMPLE
}

enum InspectionType {
  VISUAL
  FORMAL_VISUAL
  INTEGRITY_TEST
  LEAK_TEST
  DRAINAGE_RELEASE_CHECK
  OVERFILL_DEVICE_TEST
  PREVENTIVE_MAINTENANCE
}

enum AssetClass {
  BULK_STORAGE_CONTAINER
  CONTAINMENT_UNIT
  TRANSFER_AREA
  PIPING
  MOBILE_PORTABLE_CONTAINER
  FACILITY_AREA
}

enum AssetModeState {
  STATIONARY_UNATTENDED
  ACTIVE_TRANSFER_UNDER_CONTROL
}

enum CorrectiveActionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  ACCEPTED_RISK
}

enum ObligationType {
  INSPECTION_DUE
  INSPECTION_OVERDUE
  ACTION_OVERDUE
  TRAINING_DUE
  REVIEW_DUE
  SIGNATURE_MISSING
}

enum ValidationSeverity {
  HARD_FAILURE
  AT_RISK
}

enum TrainingEventType {
  ONBOARDING
  ANNUAL_BRIEFING
  REMEDIAL
}

// Phase 3 enums
enum PlanStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SUPERSEDED
}

enum PlanCertificationType {
  OWNER_OPERATOR_SELF_CERTIFIED
  PE_CERTIFIED
}

enum ReviewStatus {
  UPCOMING
  DUE
  COMPLETED
  OVERDUE
}

enum AmendmentType {
  FIVE_YEAR_REVIEW
  ASSET_CHANGE
  OWNERSHIP_CHANGE
  INCIDENT
  PROCEDURAL_CHANGE
  CONSULTANT_RECOMMENDATION
}

enum AmendmentStatus {
  OPEN
  DRAFTING
  READY_FOR_APPROVAL
  IMPLEMENTED
  CLOSED
}

enum TechnicalChangeType {
  TECHNICAL
  NON_TECHNICAL
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ExportType {
  PLAN_PDF
  INSPECTION_REPORT
  CORRECTIVE_ACTION_REGISTER
  TRAINING_LOG
  CONTAINER_INVENTORY
  CONTAINMENT_BASIS
  REVIEW_MEMO
  INCIDENT_LOG
  FULL_AUDIT_PACK
}

enum ExportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// ============ CORE AUTH / ORG ============

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  emailVerified  DateTime?
  passwordHash   String?
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationMemberships OrganizationMembership[]
  facilityMemberships     FacilityMembership[]
  assessedApplicability   FacilityApplicabilityAssessment[] @relation("AssessedByUser")
  assessedQualification   FacilityQualificationRecord[]     @relation("AssessedByUser")
  uploadedFiles          FileAsset[]
  auditEvents            AuditEvent[]                      @relation("ActorUser")

  // Phase 2
  inspectionRuns              InspectionRun[]         @relation("PerformedByUser")
  correctiveActionsOwned      CorrectiveAction[]      @relation("ActionOwner")
  correctiveActionsVerified   CorrectiveAction[]      @relation("ActionVerifiedBy")
  trainingAttendance          TrainingAttendance[]
  trainingSignatures          TrainingSignature[]

  // Phase 3
  planVersionsCreated  PlanVersion[] @relation("PlanVersionCreatedBy")
  planVersionsApproved PlanVersion[] @relation("PlanVersionApprovedBy")
  exportJobsRequested  ExportJob[]   @relation("ExportRequestedBy")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  OrganizationMembership[]
  facilities   Facility[]
  auditEvents  AuditEvent[]
  regulatoryRequirements RegulatoryRequirement[]
  inspectionTemplates  InspectionTemplate[]
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           UserRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Facility {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  slug           String
  status         FacilityStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization     Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships      FacilityMembership[]
  profile          FacilityProfile?
  applicability    FacilityApplicabilityAssessment[]
  qualification    FacilityQualificationRecord[]
  accountablePerson FacilityAccountablePerson?
  assets           Asset[]
  containmentUnits ContainmentUnit[]
  transferAreas    TransferArea[]
  files            FileAsset[]
  auditEvents      AuditEvent[]

  // Phase 2
  inspectionTemplates  InspectionTemplate[]
  scheduledInspections ScheduledInspection[]
  inspectionRuns       InspectionRun[]
  correctiveActions   CorrectiveAction[]
  personnel           Personnel[]
  trainingEvents      TrainingEvent[]
  obligationRecords   ObligationRecord[]
  validationResults   ValidationResult[]

  // Phase 3
  plan            Plan?
  planVersions    PlanVersion[]
  planReviews     PlanReview[]
  planAmendments  PlanAmendment[]
  incidents       Incident[]
  exportJobs      ExportJob[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model FacilityMembership {
  id         String   @id @default(cuid())
  facilityId String
  userId     String
  role       UserRole
  createdAt  DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([facilityId, userId])
  @@index([facilityId])
  @@index([userId])
}

// ============ FACILITY MASTER DATA ============

model FacilityProfile {
  id                          String    @id @default(cuid())
  facilityId                  String    @unique
  legalName                   String?
  dbaName                     String?
  addressLine1                String?
  addressLine2                String?
  city                        String?
  state                       String?
  postalCode                  String?
  country                     String?   @default("US")
  latitude                    Float?
  longitude                   Float?
  naicsCode                   String?
  industry                    String?
  dischargeExpectationNarrative String?  @db.Text
  nearestWaterbody            String?
  operatingHours              String?
  consultantOfRecord          String?
  emergencyContactName        String?
  emergencyContactPhone       String?
  currentPlanEffectiveDate    DateTime?
  nextFiveYearReviewDate      DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

model FacilityApplicabilityAssessment {
  id                               String             @id @default(cuid())
  facilityId                       String
  nonTransportationRelated         Boolean
  aggregateAbovegroundCapacityGallons Int
  completelyBuriedCapacityGallons  Int
  hasReasonableExpectationOfDischarge Boolean
  hasContainersBelow55Excluded     Boolean
  hasPermanentlyClosedContainersExcluded Boolean
  hasMotivePowerContainersExcluded Boolean
  hasWastewaterTreatmentExclusions Boolean
  spccApplicable                   Boolean
  notes                            String?            @db.Text
  assessedAt                       DateTime
  assessedByUserId                 String

  facility      Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  assessedBy    User     @relation("AssessedByUser", fields: [assessedByUserId], references: [id], onDelete: Restrict)

  @@index([facilityId])
}

model FacilityQualificationRecord {
  id                              String            @id @default(cuid())
  facilityId                      String
  qualifiedFacility               Boolean
  tier                            QualificationTier
  maxIndividualContainerGallons   Int?
  singleDischargeGt1000Last3Years Boolean
  twoDischargesGt42Within12MonthsLast3Years Boolean
  qualificationRationale         String?           @db.Text
  v1Fit                          String?           // ideal | acceptable | out_of_scope
  assessedAt                     DateTime
  assessedByUserId               String

  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  assessedBy  User     @relation("AssessedByUser", fields: [assessedByUserId], references: [id], onDelete: Restrict)

  @@index([facilityId])
}

model FacilityAccountablePerson {
  id         String   @id @default(cuid())
  facilityId String   @unique
  name       String
  title      String?
  email      String
  phone      String?
  appointedAt DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
}

// ============ ASSETS AND CONTAINMENT ============

model OilType {
  id       String          @id @default(cuid())
  label    String
  category OilTypeCategory
  active   Boolean         @default(true)

  assets Asset[]
}

model Asset {
  id                      String       @id @default(cuid())
  facilityId              String
  assetCode               String
  name                    String
  assetType               AssetType
  oilTypeId               String?
  storageCapacityGallons  Int?
  typicalFillPercent      Int?
  countedTowardThreshold  Boolean      @default(true)
  exclusionReason         String?      @db.Text
  aboveground             Boolean      @default(true)
  indoor                  Boolean?
  status                  AssetStatus  @default(ACTIVE)
  installDate             DateTime?
  retirementDate          DateTime?
  manufacturer            String?
  material                String?
  dimensions              String?      @db.Text
  overfillProtectionNotes String?      @db.Text
  integrityTestingBasis   String?      @db.Text
  inspectionFrequencyDays Int?
  lastInspectionDate      DateTime?
  nextInspectionDate      DateTime?
  comments                String?      @db.Text
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  facility      Facility               @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  oilType       OilType?               @relation(fields: [oilTypeId], references: [id], onDelete: SetNull)
  containmentLinks AssetContainmentLink[]

  // Phase 2 extensions
  assetClass                AssetClass?
  modeState                 AssetModeState?
  requiresSizedContainment  Boolean      @default(false)
  underDirectControl        Boolean?
  containmentValidationBasis String?     @db.Text

  correctiveActions        CorrectiveAction[]
  scheduledInspections     ScheduledInspection[]
  incidents                Incident[]

  @@unique([facilityId, assetCode])
  @@index([facilityId])
  @@index([oilTypeId])
}

model ContainmentUnit {
  id                           String          @id @default(cuid())
  facilityId                   String
  code                         String
  name                         String
  containmentType              ContainmentType
  largestSingleTankCapacityGallons Int?
  capacityCalculationMethod    String?         @db.Text
  calculatedCapacityGallons    Int?
  drainageControlNotes         String?         @db.Text
  conditionStatus              ConditionStatus?
  lastInspectionDate           DateTime?
  comments                     String?         @db.Text
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt

  facility      Facility              @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  assetLinks    AssetContainmentLink[]

  @@unique([facilityId, code])
  @@index([facilityId])
}

model AssetContainmentLink {
  id                String @id @default(cuid())
  assetId           String
  containmentUnitId String

  asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  containmentUnit ContainmentUnit @relation(fields: [containmentUnitId], references: [id], onDelete: Cascade)

  @@unique([assetId, containmentUnitId])
  @@index([containmentUnitId])
}

model TransferArea {
  id             String   @id @default(cuid())
  facilityId     String
  name           String
  description    String?  @db.Text
  drainageControls String? @db.Text
  comments       String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

// ============ FILES ============

model FileAsset {
  id             String        @id @default(cuid())
  facilityId     String
  objectType     FileObjectType
  objectId       String
  fileName       String
  mimeType       String
  storageKey     String
  checksum       String?
  uploadedByUserId String
  uploadedAt     DateTime      @default(now())
  caption        String?

  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([facilityId])
  @@index([objectType, objectId])
}

// ============ AUDIT ============

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String?
  facilityId     String?
  actorUserId    String?
  objectType     String
  objectId       String?
  action         String
  beforeJson     Json?
  afterJson      Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  facility     Facility?     @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  actor        User?        @relation("ActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([facilityId])
  @@index([actorUserId])
  @@index([createdAt])
}

// ============ PHASE 2: REGULATORY LAYER ============

model RegulatoryRequirement {
  id                    String              @id @default(cuid())
  organizationId        String
  requirementCode       String
  title                 String
  sourceType            RequirementSourceType
  citationRef           String?             @db.Text
  controllingSection    String?
  summary               String?             @db.Text
  evidenceRequirementsJson Json?
  severityModel         String?
  active                Boolean             @default(true)
  createdAt             DateTime            @default(now())

  organization         Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateItems        InspectionTemplateItem[]
  correctiveActions    CorrectiveAction[]

  @@unique([organizationId, requirementCode])
  @@index([organizationId])
}

// ============ PHASE 2: INSPECTION SYSTEM ============

model InspectionTemplate {
  id              String   @id @default(cuid())
  organizationId  String
  facilityId      String?  // null = org-wide template
  name            String
  assetClass      AssetClass
  inspectionType  InspectionType
  standardBasisRef String? @db.Text
  procedureText   String?  @db.Text
  expectedFrequencyDays Int?
  performerQualificationBasis String? @db.Text
  requiredEvidenceTypes  String? @db.Text  // JSON array of types
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility     Facility?    @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  versions  InspectionTemplateVersion[]
  scheduledInspections ScheduledInspection[]

  @@index([organizationId])
  @@index([facilityId])
}

model InspectionTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    InspectionTemplateItem[]

  @@unique([templateId, version])
  @@index([templateId])
}

model InspectionTemplateItem {
  id                      String   @id @default(cuid())
  templateVersionId       String
  sequenceOrder           Int
  prompt                  String   @db.Text
  responseType            String   // boolean, number, text, single_select, multi_select, photo_required, signature_required
  required                Boolean  @default(false)
  acceptableRange         String?  @db.Text  // JSON for range
  failureSeverity         CorrectiveActionSeverity?
  regulatoryRequirementId String?
  autoCreateCorrectiveAction Boolean @default(false)
  createdAt               DateTime @default(now())

  templateVersion     InspectionTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  regulatoryRequirement RegulatoryRequirement?  @relation(fields: [regulatoryRequirementId], references: [id], onDelete: SetNull)
  itemResults         InspectionItemResult[]
  correctiveActions   CorrectiveAction[]

  @@index([templateVersionId])
}

model ScheduledInspection {
  id              String   @id @default(cuid())
  facilityId      String
  templateId      String
  assetId         String?
  dueDate         DateTime
  recurrenceRule  String?  @db.Text
  assignedUserId  String?
  status          String   // scheduled, in_progress, completed, missed, canceled
  priority        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  facility  Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  template  InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  asset     Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  runs      InspectionRun[]

  @@index([facilityId])
  @@index([dueDate])
  @@index([status])
}

model InspectionRun {
  id                    String   @id @default(cuid())
  scheduledInspectionId String
  facilityId            String
  performedByUserId     String
  performedByNameSnapshot String
  performedByRoleSnapshot String
  qualificationBasis    String?  @db.Text
  performedAt           DateTime
  performedAtTimezone   String?
  standardBasisRef      String?  @db.Text
  procedureTextSnapshot String?  @db.Text
  status                String   // in_progress, completed
  locked                Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  scheduledInspection ScheduledInspection @relation(fields: [scheduledInspectionId], references: [id], onDelete: Cascade)
  facility            Facility            @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  performedBy         User                @relation("PerformedByUser", fields: [performedByUserId], references: [id], onDelete: Restrict)
  itemResults         InspectionItemResult[]
  signatures          InspectionSignature[]
  correctiveActions   CorrectiveAction[]

  @@index([facilityId])
  @@index([performedByUserId])
  @@index([performedAt])
}

model InspectionItemResult {
  id              String   @id @default(cuid())
  inspectionRunId String
  templateItemId  String
  responseValue   Json?    // stores the actual response
  pass            Boolean?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  inspectionRun InspectionRun       @relation(fields: [inspectionRunId], references: [id], onDelete: Cascade)
  templateItem  InspectionTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Restrict)

  @@unique([inspectionRunId, templateItemId])
  @@index([inspectionRunId])
}

model InspectionSignature {
  id              String   @id @default(cuid())
  inspectionRunId String
  signerUserId    String?
  signerName      String
  signerRole      String?
  signedAt        DateTime
  signatureData   String?  @db.Text  // base64 or ref to stored signature
  createdAt       DateTime @default(now())

  inspectionRun InspectionRun @relation(fields: [inspectionRunId], references: [id], onDelete: Cascade)

  @@index([inspectionRunId])
}

// ============ PHASE 2: CORRECTIVE ACTIONS ============

model CorrectiveAction {
  id                    String                 @id @default(cuid())
  facilityId            String
  assetId               String?
  regulatoryRequirementId String?
  sourceInspectionItemId String?
  sourceInspectionRunId  String?
  title                 String
  description           String?                @db.Text
  severity              CorrectiveActionSeverity
  triggerCategory       String?                // inspection_failure, audit, etc.
  ownerUserId           String
  dueDate               DateTime?
  status                CorrectiveActionStatus @default(OPEN)
  rootCause             String?                @db.Text
  closureNote           String?                @db.Text
  acceptedRiskJustification String?            @db.Text  // required when status=ACCEPTED_RISK
  verifiedByUserId      String?
  verifiedAt            DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  facility              Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  asset                 Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  regulatoryRequirement RegulatoryRequirement? @relation(fields: [regulatoryRequirementId], references: [id], onDelete: SetNull)
  sourceInspectionItem  InspectionTemplateItem? @relation(fields: [sourceInspectionItemId], references: [id], onDelete: SetNull)
  sourceInspectionRun   InspectionRun? @relation(fields: [sourceInspectionRunId], references: [id], onDelete: SetNull)
  owner                 User         @relation("ActionOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  verifiedBy            User?        @relation("ActionVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  comments              CorrectiveActionComment[]
  evidence              CorrectiveActionEvidence[]
  statusHistory         CorrectiveActionStatusHistory[]

  @@index([facilityId])
  @@index([assetId])
  @@index([status])
  @@index([dueDate])
  @@index([ownerUserId])
}

model CorrectiveActionComment {
  id        String   @id @default(cuid())
  actionId  String
  userId    String?
  content   String   @db.Text
  createdAt DateTime @default(now())

  action CorrectiveAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId])
}

model CorrectiveActionEvidence {
  id        String   @id @default(cuid())
  actionId  String
  fileId    String?  // references FileAsset or similar
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  action CorrectiveAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId])
}

model CorrectiveActionStatusHistory {
  id        String                 @id @default(cuid())
  actionId  String
  fromStatus CorrectiveActionStatus?
  toStatus   CorrectiveActionStatus
  changedAt DateTime               @default(now())
  changedByUserId String?

  action CorrectiveAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId])
}

// ============ PHASE 2: TRAINING ============

model Personnel {
  id                    String   @id @default(cuid())
  facilityId            String
  name                  String
  email                 String?
  phone                 String?
  roleTitle             String?
  oilHandlingPersonnel  Boolean  @default(false)
  active                Boolean  @default(true)
  hireDate              DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  attendance TrainingAttendance[]

  @@index([facilityId])
}

model TrainingEvent {
  id              String           @id @default(cuid())
  facilityId      String
  type            TrainingEventType
  eventDate       DateTime
  instructorName  String?
  agenda          String?          @db.Text
  linkedIncidentIds String?        @db.Text  // JSON array of incident refs
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  attendance TrainingAttendance[]
  signatures TrainingSignature[]

  @@index([facilityId])
  @@index([eventDate])
}

model TrainingAttendance {
  id           String   @id @default(cuid())
  eventId      String
  personnelId  String
  userId       String?  // optional link to User if attendee is a system user
  attended     Boolean  @default(true)
  createdAt    DateTime @default(now())

  event     TrainingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  personnel Personnel     @relation(fields: [personnelId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([eventId, personnelId])
  @@index([eventId])
}

model TrainingSignature {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  signedAt    DateTime
  signatureData String? @db.Text
  createdAt   DateTime @default(now())

  event TrainingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

// ============ PHASE 2: OBLIGATIONS + VALIDATION ============

model ObligationRecord {
  id                String        @id @default(cuid())
  facilityId        String
  requirementCode   String
  obligationType    ObligationType
  sourceObjectType  String
  sourceObjectId    String?
  severity          ValidationSeverity
  status            String        // open, satisfied
  dueDate           DateTime?
  satisfiedAt       DateTime?
  evidenceObjectType String?
  evidenceObjectId  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@index([status])
  @@index([dueDate])
  @@index([obligationType])
}

model ValidationResult {
  id           String   @id @default(cuid())
  facilityId   String
  computedAt   DateTime @default(now())
  hardFailures Json     // JSON array of failure objects
  riskFlags    Json     // JSON array of risk flag objects
  overallStatus String  // COMPLIANT, AT_RISK, NONCOMPLIANT

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

// ============ PHASE 3: PLAN SYSTEM ============

model Plan {
  id                String   @id @default(cuid())
  facilityId        String   @unique
  currentVersionId  String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  facility       Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  currentVersion PlanVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions       PlanVersion[] @relation("PlanVersions")

  @@index([facilityId])
}

model PlanVersion {
  id                      String             @id @default(cuid())
  planId                  String
  facilityId              String
  versionNumber           Int
  status                  PlanStatus
  qualificationTierSnapshot String?
  certificationType       PlanCertificationType?
  effectiveDate           DateTime?
  supersededDate          DateTime?
  reviewDueDate           DateTime?
  generatedDocumentPath   String?
  lockedSnapshotJson      Json?
  createdByUserId         String
  approvedByUserId        String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  plan             Plan              @relation("PlanVersions", fields: [planId], references: [id], onDelete: Cascade)
  facility         Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  createdBy        User              @relation("PlanVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedBy       User?             @relation("PlanVersionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  sections         PlanSection[]
  certifications   PlanCertification[]
  reviews          PlanReview[]
  amendments       PlanAmendment[]
  planAsCurrent    Plan?             @relation("CurrentVersion")

  @@unique([planId, versionNumber])
  @@index([facilityId])
  @@index([status])
}

model PlanSection {
  id               String   @id @default(cuid())
  planVersionId    String
  sectionKey       String
  title            String
  sectionOrder     Int
  contentMode      String   // STRUCTURED, NARRATIVE, HYBRID
  structuredDataJson Json?
  narrativeText    String?  @db.Text
  generatedFromSystem Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  planVersion PlanVersion           @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  revisions   PlanSectionRevision[]

  @@unique([planVersionId, sectionKey])
  @@index([planVersionId])
}

model PlanSectionRevision {
  id             String   @id @default(cuid())
  planSectionId  String
  revisionNumber Int
  beforeJson     Json?
  afterJson      Json?
  editedByUserId String?
  createdAt      DateTime @default(now())

  planSection PlanSection @relation(fields: [planSectionId], references: [id], onDelete: Cascade)

  @@index([planSectionId])
}

model PlanCertification {
  id                String               @id @default(cuid())
  planVersionId     String
  certificationType PlanCertificationType
  certifiedByName   String
  certifiedByTitle  String?
  certificationDate DateTime
  siteVisitDate     DateTime?
  notes             String?              @db.Text
  createdAt         DateTime             @default(now())

  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@index([planVersionId])
}

model PlanReview {
  id                String       @id @default(cuid())
  facilityId        String
  planVersionId     String
  dueDate           DateTime
  completedAt       DateTime?
  completedByUserId String?
  status            ReviewStatus
  summary           String?      @db.Text
  requiresAmendment Boolean      @default(false)
  notes             String?      @db.Text
  createdAt         DateTime     @default(now())

  facility    Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  planVersion PlanVersion  @relation(fields: [planVersionId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@index([planVersionId])
  @@index([status])
}

model PlanAmendment {
  id                 String          @id @default(cuid())
  facilityId         String
  planVersionId      String?
  amendmentType      AmendmentType
  technicalChangeType TechnicalChangeType?
  description        String          @db.Text
  dueBy              DateTime?
  implementedBy      String?
  status             AmendmentStatus
  affectedSectionsJson String?       @db.Text
  requiresPe         Boolean         @default(false)
  createdByUserId   String
  completedAt       DateTime?
  createdAt         DateTime        @default(now())

  facility    Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  planVersion PlanVersion? @relation(fields: [planVersionId], references: [id], onDelete: SetNull)

  @@index([facilityId])
  @@index([status])
}

// ============ PHASE 3: INCIDENT SYSTEM ============

model Incident {
  id                         String           @id @default(cuid())
  facilityId                 String
  sourceAssetId              String?
  title                      String
  occurredAt                 DateTime
  estimatedTotalSpilledGallons Float?
  estimatedAmountToWaterGallons Float?
  impactedWaterbody          String?
  cause                      String?          @db.Text
  immediateActions           String?          @db.Text
  notes                      String?          @db.Text
  severity                   IncidentSeverity
  createdByUserId            String
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  facility    Facility       @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  sourceAsset Asset?         @relation(fields: [sourceAssetId], references: [id], onDelete: SetNull)
  files       IncidentFile[]

  @@index([facilityId])
  @@index([occurredAt])
}

model IncidentFile {
  id         String   @id @default(cuid())
  incidentId String
  fileName   String
  storageKey String
  mimeType   String
  caption    String?
  uploadedByUserId String
  createdAt  DateTime @default(now())

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

// ============ PHASE 3: EXPORT SYSTEM ============

model ExportJob {
  id                String       @id @default(cuid())
  facilityId        String
  exportType        ExportType
  status            ExportStatus
  requestedByUserId String
  requestedAt       DateTime     @default(now())
  completedAt       DateTime?
  failedAt          DateTime?
  errorMessage      String?      @db.Text
  parametersJson    Json?

  facility   Facility         @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  requestedBy User            @relation("ExportRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  artifacts  ExportArtifact[]

  @@index([facilityId])
  @@index([status])
}

model ExportArtifact {
  id             String   @id @default(cuid())
  exportJobId    String
  fileName       String
  storageKey     String
  mimeType       String
  generatedAt    DateTime @default(now())
  createdByUserId String?

  exportJob ExportJob @relation(fields: [exportJobId], references: [id], onDelete: Cascade)

  @@index([exportJobId])
}

// ============ AI / RAG (compliance knowledge) ============

model ComplianceKnowledgeChunk {
  id         String   @id @default(cuid())
  source     String
  chunkIndex Int
  title      String
  content    String   @db.Text
  embedding  Json
  createdAt  DateTime @default(now())

  @@unique([source, chunkIndex])
  @@index([source])
}
